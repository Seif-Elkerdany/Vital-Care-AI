FROM node:20-alpine AS builder

WORKDIR /app

COPY Medical_app_UI/package.json Medical_app_UI/package-lock.json ./
RUN npm ci

COPY Medical_app_UI/ .
RUN npm run build

FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
