FROM python:3.11-slim

RUN apt-get update && apt-get install -y \
    ffmpeg \
    libsndfile1 \
    libportaudio2 \
    portaudio19-dev \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install CPU-only PyTorch first to keep image smaller
RUN pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu

COPY requirements.txt .
COPY backend_api/LLM/requirements.txt backend_api/LLM/
COPY backend_api/RAG/requirements.txt backend_api/RAG/
COPY backend_api/STT/requirements.txt backend_api/STT/
COPY backend_api/TTS/requirements.txt backend_api/TTS/
RUN pip install --no-cache-dir -r requirements.txt

COPY backend_api/ ./backend_api/
COPY server.py .

ENV PYTHONPATH=/app
ENV HF_HOME=/app/.cache/huggingface

EXPOSE 8000

CMD ["python", "server.py", "--host", "0.0.0.0", "--port", "8000"]
